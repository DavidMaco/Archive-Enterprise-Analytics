# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for local development.
# On Streamlit Cloud, paste these key-value pairs into
#   App settings → Secrets (do NOT commit secrets.toml to version control).
#
# All of these can also be supplied as OS environment variables with the same
# names, which is the preferred method for non-Streamlit deployments.
# ─────────────────────────────────────────────────────────────────────────────

# Absolute path to the folder containing the raw archive parquet/SQLite files.
# Leave blank to use data/raw/ inside the project root (e.g. pre-seeded data).
ARCHIVE_ANALYTICS_RAW_DIR = "/mnt/data/archive_raw"

# Set to "true" to show Build / Train buttons on the home page.
# Keep "false" (default) for read-only public deployments.
ARCHIVE_ANALYTICS_ENABLE_UI_MUTATIONS = "false"
